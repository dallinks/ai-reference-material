{
  "name": "ai-reference",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "export:md": "node scripts/export-markdown.mjs",
    "export:html": "node scripts/export-html.mjs",
    "export:assessments": "node scripts/export-assessments.mjs",
    "export:metadata": "node scripts/export-metadata.mjs",
    "export": "npm run export:md && npm run export:html && npm run export:assessments && npm run export:metadata",
    "build:epub": "pandoc export/markdown/COURSE.md -o export/course.epub --toc --metadata title=\"AI Implementation Reference\"",
    "build:pdf": "pandoc export/markdown/COURSE.md -o export/course.pdf --toc"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.0"
  }
}
